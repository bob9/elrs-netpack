# Waveshare ESP32-S3-ETH (standard and PoE variants)
# ESP32-S3 + W5500 SPI Ethernet
CONFIG_IDF_TARGET="esp32s3"

CONFIG_ETHERNET_SPI_SUPPORT=y
CONFIG_ETHERNET_USE_W5500=y
CONFIG_ETHERNET_SPI_SCLK_GPIO=13
CONFIG_ETHERNET_SPI_MOSI_GPIO=11
CONFIG_ETHERNET_SPI_MISO_GPIO=12
CONFIG_ETHERNET_SPI_CS0_GPIO=14
CONFIG_ETHERNET_SPI_INT0_GPIO=10
CONFIG_ETHERNET_SPI_PHY_RST0_GPIO=9
CONFIG_ETHERNET_SPI_PHY_ADDR0=1

# Serial console on the chip's native USB port
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Board has 16 MB flash; two 3 MB OTA slots
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_16mb.csv"
